# Server Configuration
PORT=5000
FRONTEND_URLS=http://localhost:5173,https://your-vercel-project.vercel.app

# Database Configuration (Option A: Connection String - Recommended for Cloud)
# DATABASE_URL=mysql://user:password@host:port/dbname

# Database Configuration (Option B: Individual Variables - Best for Local)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ai_career_launchpad

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=30d

# Groq AI Integration
GROQ_API_KEY=gsk_your_groq_api_key_here

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
